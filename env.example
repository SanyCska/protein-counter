TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
OPENAI_API_KEY=sk-...
# Optional: model for AI protein estimates (default: gpt-4o-mini)
# OPENAI_MODEL=gpt-4o-mini
# Optional: IANA timezone for “today” (default: UTC)
# TZ=Europe/Berlin
# Optional: SQLite path (default: data/protein.sqlite3 locally; in Docker use /app/data/protein.sqlite3)
# PROTEIN_DB_PATH=data/protein.sqlite3
